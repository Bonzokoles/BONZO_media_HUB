# BONZO Media Hub - Environment Variables
# Copy this file to .env.local and fill in your values

# ====================================
# Cloudflare R2 Storage Configuration
# ====================================
# Get these from: Cloudflare Dashboard > R2 > Manage R2 API Tokens

# Your Cloudflare Account ID
R2_ACCOUNT_ID=your_account_id_here

# R2 API Token Access Key ID
R2_ACCESS_KEY_ID=your_access_key_id_here

# R2 API Token Secret Access Key (keep this secret!)
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# R2 Bucket Name (default: bonzo-media-hub)
R2_BUCKET_NAME=bonzo-media-hub

# R2 Public URL (from bucket settings)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxx.r2.dev

# ====================================
# R2 Catalog URLs (Public Access)
# ====================================
# These are set automatically after running: node scripts/upload-to-r2.mjs
# Update these in your Cloudflare Pages environment variables

NEXT_PUBLIC_R2_FILM_CATALOG_HTML=https://pub-xxxxxxxxxxxxx.r2.dev/catalogs/film-catalog.html
NEXT_PUBLIC_R2_FILM_CATALOG_JSON=https://pub-xxxxxxxxxxxxx.r2.dev/catalogs/film-catalog.json
NEXT_PUBLIC_R2_MUSIC_CATALOG_JSON=https://pub-xxxxxxxxxxxxx.r2.dev/catalogs/music-catalog.json

# ====================================
# TMDB (The Movie Database) API
# ====================================
# Get your API key from: https://www.themoviedb.org/settings/api

# TMDB API Key (v3 auth)
TMDB_API_KEY=your_tmdb_api_key_here

# TMDB Read Access Token (v4 auth - optional)
TMDB_READ_TOKEN=your_tmdb_read_token_here

# ====================================
# DeepSeek AI API
# ====================================
# Get your API key from: https://platform.deepseek.com

DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ====================================
# OpenAI API
# ====================================
# Get your API key from: https://platform.openai.com/api-keys

OPENAI_API_KEY=your_openai_api_key_here

# ====================================
# Cloudflare Pages Configuration
# ====================================
# For local development with Cloudflare Pages Functions

# Cloudflare Account ID (same as R2_ACCOUNT_ID)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Cloudflare API Token (for deployment)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# ====================================
# Application Settings
# ====================================

# Next.js public base path (for AI endpoints)
NEXT_PUBLIC_BASE_PATH=/ai-hub

# Node environment
NODE_ENV=development

# ====================================
# Analytics (Optional)
# ====================================

# Vercel Analytics (if using Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id_here

# Google Analytics (optional)
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# ====================================
# Security (Optional)
# ====================================

# Enable/disable certain features
# NEXT_PUBLIC_ENABLE_AI_FEATURES=true
# NEXT_PUBLIC_ENABLE_MUSIC_FEATURES=true
# NEXT_PUBLIC_ENABLE_FILM_FEATURES=true

# ====================================
# IMPORTANT NOTES
# ====================================
#
# 1. Never commit .env.local to version control!
# 2. R2 credentials are for SERVER-SIDE use only
# 3. NEXT_PUBLIC_* variables are exposed to the browser
# 4. Update Cloudflare Pages environment variables after local setup
# 5. Run `node scripts/upload-to-r2.mjs` after setting R2 credentials
#
# Setup Guide: See R2_SETUP.md for detailed instructions
