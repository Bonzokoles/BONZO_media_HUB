    if (film.posterUrl) candidates.push(film.posterUrl);

    if (film.tmdbId) {
      candidates.push(buildR2AssetUrl(`movies/posters/${film.tmdbId}.webp`));
      candidates.push(buildR2AssetUrl(`movies/posters/${film.tmdbId}.jpg`));
